# https://editorconfig.org — matches Cursor.code-workspace `files.eol` / newline settings
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
trim_trailing_whitespace = true

[*.{json,jsonc,code-workspace}]
indent_style = space
indent_size = 2

[*.sh]
indent_style = space
indent_size = 2
