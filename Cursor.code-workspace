{
  // このファイルは「マルチルートワークスペース」定義。Cursor / VS Code で開く。
  // 厳密な JSON ではなくコメント付き JSON（JSONC）として解釈される。
  "$schema": "https://json.schemastore.org/code-workspace",

  // 左のエクスプローラに並ぶフォルダ一覧。順番は表示順。
  // README の「Workspace」表と整合させること（追加・削除時は両方更新）。
  // name: タスクや ${workspaceFolder:名前} で参照するラベル（path のフォルダ名と一致させると分かりやすい）
  // path: このファイル（Cursor リポジトリのルート）から見た相対パス
  "folders": [
    {
      "name": "Cursor",
      "path": "."
    },
    {
      "name": "DiscordBot",
      "path": "../DiscordBot"
    },
    {
      "name": "Portfolio",
      "path": "../Portfolio"
    },
    {
      "name": "MotionDesktop",
      "path": "../MotionDesktop"
    }
  ],

  // ワークスペース全体に効く設定（各リポジトリ内の .vscode/settings.json はそれより優先されることが多い）
  "settings": {
    // マルチルートで「今どのフォルダのファイルか」をタイトルバーに表示する
    "window.title": "${dirty}${activeEditorShort}${separator}${rootName}",
    // タブ名にディレクトリを含めやすくし、同名ファイルの取り違いを防ぐ
    "workbench.editor.labelFormat": "medium",
    // シングルクリックでプレビュータブにしない（複数リポジトリ間の行き来でタブが消えにくくなる）
    "workbench.editor.enablePreview": false,

    // 新規統合ターミナルの開始ディレクトリ。Git 配下にまとめて作業する想定で Cursor の親フォルダへ。
    "terminal.integrated.cwd": "${workspaceFolder:Cursor}/..",
    // ターミナルに保持するスクロールバック行数
    "terminal.integrated.scrollback": 5000,

    // --- Git（拡張機能の Git ビュー・バックグラウンド更新）---
    "git.autoFetch": true,
    // 何秒ごとに自動 fetch するか（例: 180 = 約 3 分）
    "git.autofetchPeriod": 180,
    // fetch 時にリモートで削除されたブランチ参照をローカルからも整理する
    "git.pruneOnFetch": true,

    // --- ソース管理パネル ---
    // tree: 変更ファイルをツリー表示 / list: フラット一覧
    "scm.defaultViewMode": "tree",
    // 「ソース管理リポジトリ」ビューに同時に見せる件数の上限（だいたいの複数ルート用に 10）
    "scm.repositories.visible": 10,

    // --- ファイルの改行・末尾 ---
    "files.eol": "\n",
    "files.insertFinalNewline": true,
    "files.trimTrailingWhitespace": true,
    // エクスプローラだけから隠す（ディスク上はそのまま）
    "files.exclude": {
      "**/.DS_Store": true
    },
    // true のとき .gitignore に載ったファイルはサイドバーでもグレーアウト／除外されやすい
    "explorer.excludeGitIgnore": true,

    // --- ファイル監視の除外（インデックス・ウォッチャ負荷軽減。編集の対象にはしないディレクトリ向け）---
    "files.watcherExclude": {
      "**/.git/objects/**": true,
      "**/.git/subtree-cache/**": true,
      "**/node_modules/**": true,
      "**/.next/**": true,
      "**/out/**": true,
      "**/dist/**": true,
      "**/build/**": true,
      "**/target/**": true,
      "**/coverage/**": true,
      "**/.turbo/**": true,
      "**/.cache/**": true,
      "**/.venv/**": true
    },
    // --- ワークスペース検索（Ctrl/Cmd+Shift+F）から除外 ---※ロックファイルは検索したいことがあるので含めていない
    "search.exclude": {
      "**/node_modules": true,
      "**/.next": true,
      "**/out": true,
      "**/dist": true,
      "**/build": true,
      "**/target": true,
      "**/coverage": true,
      "**/.turbo": true,
      "**/.cache": true,
      "**/.venv": true
    }
  },

  // 推奨拡張機能。ワークスペースを開いたときにインストールを促せる（チームで揃えたいときに便利）
  "extensions": {
    "recommendations": [
      // ルートに .editorconfig があればインデントなどを合わせる
      "editorconfig.editorconfig"
    ]
  },

  // タスク: 「ターミナル → タスクの実行」または Cmd/Ctrl+Shift+B（既定ビルドは Git fetch 全体）
  // Git: status all workspaces はログが混ざらないよう各リポジトリを順に実行する
  "tasks": {
    "version": "2.0.0",
    "tasks": [
      {
        "label": "Git: fetch all workspaces",
        "dependsOn": [
          "Git: fetch (Cursor)",
          "Git: fetch (DiscordBot)",
          "Git: fetch (Portfolio)",
          "Git: fetch (MotionDesktop)"
        ],
        "dependsOrder": "parallel",
        "problemMatcher": [],
        "group": {
          "kind": "build",
          "isDefault": true
        },
        "presentation": {
          "reveal": "always",
          "panel": "shared",
          "showReuseMessage": false,
          "clear": false
        }
      },
      {
        "label": "Git: status all workspaces",
        "dependsOn": [
          "Git: status (Cursor)",
          "Git: status (DiscordBot)",
          "Git: status (Portfolio)",
          "Git: status (MotionDesktop)"
        ],
        "dependsOrder": "sequence",
        "problemMatcher": [],
        "presentation": {
          "reveal": "always",
          "panel": "shared",
          "showReuseMessage": true,
          "clear": true
        }
      },
      {
        "label": "Git: fetch (Cursor)",
        "type": "shell",
        "command": "git fetch --all --prune",
        "options": {
          "cwd": "${workspaceFolder:Cursor}"
        },
        "problemMatcher": [],
        "presentation": {
          "reveal": "silent",
          "panel": "shared"
        }
      },
      {
        "label": "Git: fetch (DiscordBot)",
        "type": "shell",
        "command": "git fetch --all --prune",
        "options": {
          "cwd": "${workspaceFolder:DiscordBot}"
        },
        "problemMatcher": [],
        "presentation": {
          "reveal": "silent",
          "panel": "shared"
        }
      },
      {
        "label": "Git: fetch (Portfolio)",
        "type": "shell",
        "command": "git fetch --all --prune",
        "options": {
          "cwd": "${workspaceFolder:Portfolio}"
        },
        "problemMatcher": [],
        "presentation": {
          "reveal": "silent",
          "panel": "shared"
        }
      },
      {
        "label": "Git: fetch (MotionDesktop)",
        "type": "shell",
        "command": "git fetch --all --prune",
        "options": {
          "cwd": "${workspaceFolder:MotionDesktop}"
        },
        "problemMatcher": [],
        "presentation": {
          "reveal": "silent",
          "panel": "shared"
        }
      },
      {
        "label": "Git: status (Cursor)",
        "type": "shell",
        "command": "echo '=== Cursor ===' && git status -sb",
        "options": {
          "cwd": "${workspaceFolder:Cursor}"
        },
        "problemMatcher": [],
        "presentation": {
          "reveal": "silent",
          "panel": "shared"
        }
      },
      {
        "label": "Git: status (DiscordBot)",
        "type": "shell",
        "command": "echo '=== DiscordBot ===' && git status -sb",
        "options": {
          "cwd": "${workspaceFolder:DiscordBot}"
        },
        "problemMatcher": [],
        "presentation": {
          "reveal": "silent",
          "panel": "shared"
        }
      },
      {
        "label": "Git: status (Portfolio)",
        "type": "shell",
        "command": "echo '=== Portfolio ===' && git status -sb",
        "options": {
          "cwd": "${workspaceFolder:Portfolio}"
        },
        "problemMatcher": [],
        "presentation": {
          "reveal": "silent",
          "panel": "shared"
        }
      },
      {
        "label": "Git: status (MotionDesktop)",
        "type": "shell",
        "command": "echo '=== MotionDesktop ===' && git status -sb",
        "options": {
          "cwd": "${workspaceFolder:MotionDesktop}"
        },
        "problemMatcher": [],
        "presentation": {
          "reveal": "silent",
          "panel": "shared"
        }
      }
    ]
  }
}
